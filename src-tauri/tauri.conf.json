{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "nine-snake",
  "mainBinaryName": "nine-snake",
  "version": "1.1.10",
  "identifier": "com.nine-snake.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "九头蛇 · nine-snake",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' '${TAURI_NONCE}'; script-src 'self' '${TAURI_NONCE}'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:11434 https://*.ollama.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "九头蛇 — 多头 AI 助手",
    "longDescription": "A multi-headed AI agent that grows with you. 写作 / 工作 / 代码 一体。",
    "publisher": "AQWlala",
    "homepage": "https://github.com/AQWlala/nine-snake"
  },
  "plugins": {
    "globalShortcut": {
      "shortcut": "CmdOrCtrl+Shift+H"
    },
    "updater": {
      "pubkey": "vl2AY5Eme9dkHDZG0e/4e+cFmuk/41zgGH9LCAmflVc="
    },
    "autostart": null
  }
}
